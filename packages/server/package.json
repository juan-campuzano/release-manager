{
    "name": "@release-manager/server",
    "version": "1.0.0",
    "description": "Express.js API server for Release Manager",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsc && node dist/server.js",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:integration": "tsc && node dist/integration-test.js",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@octokit/rest": "^22.0.1",
        "azure-devops-node-api": "^15.1.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "ws": "^8.16.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "@types/ws": "^8.5.10",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.40.0",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.0"
    }
}